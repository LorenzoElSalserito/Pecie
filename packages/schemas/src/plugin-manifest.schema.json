{
  "$id": "plugin-manifest.schema.json",
  "type": "object",
  "required": ["id", "schemaVersion", "label", "version", "entryPoint", "permissions", "hooks"],
  "properties": {
    "id": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "label": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "entryPoint": { "type": "string" },
    "permissions": {
      "type": "array",
      "items": {
        "enum": ["project.read", "project.write", "export.read", "export.write", "citations.write", "logs.read"]
      }
    },
    "hooks": {
      "type": "array",
      "items": {
        "enum": ["onProjectOpen", "onDocumentSave", "onExportProfileLoaded", "onExportBeforeWrite"]
      }
    },
    "enabledByDefault": { "type": "boolean" }
  },
  "additionalProperties": false
}
