{
  "name": "pecie",
  "version": "0.1.0",
  "private": true,
  "description": "Pecie - Hub di scrittura",
  "author": "Lorenzo DM",
  "license": "AGPL-3.0-only",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "generate:types": "node ./scripts/generate-types.mjs",
    "rebuild:native": "node ./scripts/rebuild-native.mjs",
    "postinstall": "npm run rebuild:native",
    "prebuild": "npm run generate:types",
    "start": "npm run start -w @pecie/desktop",
    "dev": "npm run dev -w @pecie/desktop",
    "dist:desktop": "npm run make:desktop",
    "dist:desktop:linux": "npm run make:desktop:linux:release",
    "dist:desktop:linux:deb": "npm run make:linux:deb -w @pecie/desktop",
    "dist:desktop:linux:snap": "npm run make:linux:snap -w @pecie/desktop",
    "dist:desktop:linux:appimage": "npm run make:linux:appimage -w @pecie/desktop",
    "dist:desktop:win": "npm run make:win -w @pecie/desktop",
    "dist:desktop:mac": "npm run make:mac -w @pecie/desktop",
    "build": "npm run build --workspaces --if-present",
    "package:desktop": "npm run package -w @pecie/desktop",
    "make:desktop": "npm run make -w @pecie/desktop",
    "make:desktop:linux:release": "npm run make:linux:release -w @pecie/desktop",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:e2e": "npm run test:e2e -w @pecie/testing"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.3.0",
    "@electron-forge/maker-deb": "^7.3.0",
    "@electron-forge/maker-dmg": "7.11.1",
    "@electron-forge/maker-pkg": "7.11.1",
    "@electron-forge/maker-snap": "7.11.1",
    "@electron-forge/maker-squirrel": "7.11.1",
    "@electron-forge/maker-zip": "7.11.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@eslint/js": "9.39.4",
    "@monaco-editor/react": "4.7.0",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "bootstrap-icons": "1.13.1",
    "electron": "^29.0.0",
    "electron-builder": "24.13.3",
    "electron-vite": "^2.0.0",
    "epubjs": "0.3.93",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "json-schema-to-typescript": "^13.1.2",
    "mammoth": "1.12.0",
    "marked": "^15.0.12",
    "monaco-editor": "0.55.1",
    "open-dyslexic": "1.0.3",
    "pdfjs-dist": "5.6.205",
    "prettier": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "8.58.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
